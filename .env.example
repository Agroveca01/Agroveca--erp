# Shopify API integration for 2026-01+
# ====================================
# Do NOT use static tokens, always get access token with these credentials:
SHOPIFY_SHOP=your-store-name          # Ejemplo: midominio (sin 'myshopify.com')
SHOPIFY_CLIENT_ID=your-client-id-here
SHOPIFY_CLIENT_SECRET=your-client-secret-here

